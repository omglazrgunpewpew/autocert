package main

import (
	"context"
	"flag"
	"fmt"
	"log"
	"net/http"
	"os"
	"os/signal"
	"syscall"

	"github.com/yourusername/autocert/internal/config"
	"github.com/yourusername/autocert/pkg/certificate"
	"github.com/yourusername/autocert/pkg/storage"
)

var (
	configFile = flag.String("config", "", "Path to configuration file")
	version    = "dev"
)

func main() {
	flag.Parse()

	fmt.Printf("Autocert %s starting...\n", version)

	// Load configuration
	cfg, err := config.Load(*configFile)
	if err != nil {
		log.Fatalf("Failed to load configuration: %v", err)
	}

	// Initialize storage
	store, err := storage.NewStore(cfg.Storage)
	if err != nil {
		log.Fatalf("Failed to initialize storage: %v", err)
	}

	// Initialize certificate manager
	manager, err := certificate.NewManager(certificate.Config{
		Domains:     cfg.Domains,
		Email:       cfg.Email,
		CacheDir:    cfg.CacheDir,
		RenewBefore: cfg.RenewBefore,
		Store:       store,
		AcmeConfig:  cfg.ACME,
	})
	if err != nil {
		log.Fatalf("Failed to initialize certificate manager: %v", err)
	}

	// Start HTTP server for ACME challenges
	go func() {
		log.Printf("Starting HTTP server for ACME challenges on :80")
		if err := http.ListenAndServe(":80", manager.HTTPHandler()); err != nil {
			log.Printf("HTTP server error: %v", err)
		}
	}()

	// Set up API server if enabled
	if cfg.API.Enabled {
		go startAPIServer(cfg.API, manager)
	}

	// Wait for signals
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	sigCh := make(chan os.Signal, 1)
	signal.Notify(sigCh, os.Interrupt, syscall.SIGTERM)

	<-sigCh
	log.Println("Shutting down gracefully...")

	// Trigger certificate renewal for certificates nearing expiration
	if err := manager.RenewCertificates(ctx); err != nil {
		log.Printf("Error during final certificate renewal: %v", err)
	}

	log.Println("Shutdown complete")
}

